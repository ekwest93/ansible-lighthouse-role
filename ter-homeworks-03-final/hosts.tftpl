[webservers]
%{~ for vm in webservers ~}
${vm.name} ansible_host=${vm.network_interface[0].nat_ip_address} fqdn=${vm.name}.ru-central1.internal
%{~ endfor ~}

[databases]
%{~ for name, vm in databases ~}
${name} ansible_host=${vm.network_interface[0].nat_ip_address} fqdn=${name}.ru-central1.internal
%{~ endfor ~}

[storage]
${storage.name} ansible_host=${storage.network_interface[0].nat_ip_address} fqdn=${storage.name}.ru-central1.internal
